# ─────────────────────────────────────────────────────────────────────────────
# data-pipeline/.env.example
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Project paths ────────────────────────────────────────────────────────────
PROJECT_ROOT=REPLACE_WITH_ABSOLUTE_PATH_TO_DATA_PIPELINE

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_NAME=REPLACE_WITH_DB_NAME

# ── Pipeline server auth ─────────────────────────────────────────────────────
# Must be identical in both apps/api/.env and data-pipeline/.env.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PIPELINE_API_KEY=REPLACE_WITH_SAME_VALUE_AS_API_ENV
