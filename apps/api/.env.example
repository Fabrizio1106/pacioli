# ─────────────────────────────────────────────────────────────────────────────
# apps/api/.env.example
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=REPLACE_WITH_DB_NAME
DB_USER=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_POOL_MIN=2
DB_POOL_MAX=5

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=8h

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=10

# ── Python pipeline paths ─────────────────────────────────────────────────────
PYTHON_PROJECT_ROOT=REPLACE_WITH_ABSOLUTE_PATH_TO_DATA_PIPELINE
PYTHON_EXECUTABLE=python
RAW_DATA_ROOT=REPLACE_WITH_ABSOLUTE_PATH_TO_DATA_RAW_FOLDER

# ── Pipeline server auth ──────────────────────────────────────────────────────
# Must be identical in both apps/api/.env and data-pipeline/.env.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PIPELINE_API_KEY=REPLACE_WITH_SAME_VALUE_AS_DATA_PIPELINE_ENV
